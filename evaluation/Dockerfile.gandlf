FROM ghcr.io/mlcommons/gandlf:master-cpu@sha256:c8cef7f78d3453536ca93d1dfeb7f5432ccd9f5cb03094f9d0c179487d0cd3d1

WORKDIR /usr/local/bin/

COPY utils.py .
COPY pathology/requirements.txt requirements.txt
RUN python3 -m pip install -r requirements.txt

COPY pathology/*.py .

# Override the base image's entrypoint so that GaNDLF CLI
# doesn't run by default
ENTRYPOINT [ "/usr/bin/env" ]
